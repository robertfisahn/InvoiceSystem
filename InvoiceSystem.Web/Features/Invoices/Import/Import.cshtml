@model InvoiceSystem.Web.Features.Invoices.Import.ImportInvoiceViewModel
@{
    ViewData["Title"] = "Importuj Fakturę (AI OCR)";
}
<div class="row justify-content-center" style="margin-top: var(--grid-gap);">
    @if (!Model.HasResult)
    {
        <!-- WIDOK 1: Formularz wgrywania pliku -->
        <div class="col-xl-6 col-lg-8 col-md-10">
            <div class="data-card">
                <div class="data-card__body" style="padding: var(--card-padding);">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mb-4">
                            <i class="bi bi-exclamation-triangle me-2"></i> @Html.Raw(Model.ErrorMessage)
                        </div>
                    }

                    <form asp-action="Index" method="post" enctype="multipart/form-data" id="importForm">
                        <div class="upload-area" id="dropZone">
                            <div class="upload-area__icon mb-2">
                                <i class="bi bi-cloud-arrow-up fs-1 text-primary opacity-75"></i>
                            </div>
                            <div class="upload-area__text mb-2">
                                <h5 class="fw-bold" style="color: var(--text-primary); margin-bottom: 4px;">Przeciągnij plik tutaj lub kliknij, aby wgrać z dysku</h5>
                                <p class="text-secondary small mb-0">aby wyodrębnić z niego tekst</p>
                            </div>
                            <div class="upload-area__hint small text-muted mb-2">
                                Dozwolone formaty: <strong>PDF, JPG, PNG</strong> (max. 10MB)
                            </div>
                            <input type="file" name="file" class="upload-area__input" id="fileInput" accept=".pdf,.jpg,.jpeg,.png" required />

                            <div class="selected-file d-none mt-2 p-2 rounded border" style="background-color: var(--bg-tertiary); border-color: var(--border-strong) !important;">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-file-earmark-pdf h4 me-2 text-primary" id="fileIcon"></i>
                                        <div class="text-start">
                                            <div class="fw-bold small" style="color: var(--text-primary); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" id="fileName">faktura.pdf</div>
                                            <div class="text-muted" style="font-size: 0.75rem;" id="fileSize">1.2 MB</div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-danger" style="padding: 2px 6px;" id="removeFile">
                                        <i class="bi bi-x-lg" style="font-size: 0.8rem;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-3">
                            <button type="submit" class="btn-primary-accent w-100 justify-content-center py-2" id="submitBtn" disabled>
                                <i class="bi bi-upload"></i> Wyślij i analizuj
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- WIDOK 2: Wynik ekstrakcji tekstu -->
        <div class="col-xl-8 col-lg-10 col-md-12">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success mb-3">
                    <i class="bi bi-check-circle me-2"></i> @Model.SuccessMessage
                </div>
            }

            <div class="data-card mb-3">
                <div class="data-card__header d-flex align-items-center justify-content-between" style="padding: var(--card-padding); padding-bottom: 0;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-file-earmark-text fs-4 text-primary"></i>
                        <div>
                            <h5 class="mb-0 fw-bold" style="color: var(--text-primary);">Wyodrębniony tekst</h5>
                            <span class="badge rounded-pill" style="background-color: var(--accent); color: white; font-size: 0.7rem;">
                                @(Model.DocumentType == "PDF" ? "PDF Parser" : "Tesseract OCR")
                            </span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" id="copyTextBtn" title="Kopiuj tekst">
                        <i class="bi bi-clipboard me-1"></i> Kopiuj
                    </button>
                </div>
                <div class="data-card__body" style="padding: var(--card-padding);">
                    <div id="extractedContent" class="extracted-text-box">@Model.ExtractedText</div>
                </div>
            </div>

            <div class="data-card mb-3">
                <div class="data-card__header d-flex flex-column" style="padding: var(--card-padding); padding-bottom: 0;">
                    <h5 class="mb-0 fw-bold" style="color: var(--text-primary);">Analiza AI (LLM)</h5>
                    <p class="text-muted small mb-0">Wybierz model sztucznej inteligencji, aby automatycznie wyodrębnić kontrahenta, datę i pozycje faktury.</p>
                </div>
                <div class="data-card__body" style="padding: var(--card-padding);">
                    <form asp-action="Analyze" method="post" id="aiAnalysisForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="filePath" value="@Model.FilePath" />
                        <input type="hidden" name="extractedText" value="@Model.ExtractedText" />
                        <input type="hidden" name="documentType" value="@Model.DocumentType" />

                        <div class="row align-items-end g-3">
                            <div class="col-md-6 text-start">
                                <label class="form-label text-muted small fw-bold">Dostawca LLM</label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background-color: var(--bg-tertiary); border-color: var(--border); color: var(--text-secondary);">
                                        <i class="bi bi-cpu"></i>
                                    </span>
                                    <select name="provider" id="aiProviderSelect" class="form-select" style="background-color: var(--bg-tertiary); color: var(--text-primary); border-color: var(--border);">
                                        <option value="Ollama">Ollama (lokalny LLM)</option>
                                        <option value="Groq">Groq (chmurowy LLM - szybki)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <button type="submit" class="btn-primary-accent w-100 py-2 justify-content-center" id="aiAnalyzeBtn">
                                    <span class="spinner-border spinner-border-sm me-2 d-none" id="aiSpinner" role="status" aria-hidden="true"></span>
                                    <i class="bi bi-magic me-2" id="aiMagicIcon"></i>
                                    <span id="aiButtonText">Analizuj i wypełnij formularz</span>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.SessionId) && Model.ExtractedData is not null)
            {
                <div class="data-card mt-4 mb-3 text-start" id="verificationCard">
                    <div class="data-card__header">
                        <h4 class="data-card__title" style="color: var(--text-primary);">
                            <i class="bi bi-shield-check text-primary me-2"></i> Dane wyodrębnione przez AI (Weryfikacja)
                        </h4>
                    </div>
                    <div class="data-card__body" style="padding: var(--card-padding);">
                        <form asp-action="Confirm" method="post" id="confirmOcrForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SessionId" value="@Model.SessionId" />

                            <div class="row g-3">
                                <!-- Sekcja Kontrahenta -->
                                <div class="col-md-6">
                                    <h5 class="fw-bold mb-3 border-bottom pb-2 text-secondary">
                                        <i class="bi bi-person-badge me-2"></i> Dane Kupującego (Nabywcy)
                                    </h5>
                                    
                                    @if (Model.ContractorExists)
                                    {
                                        <div class="alert alert-info py-2 px-3 mb-3 d-flex align-items-center" style="background: rgba(99,102,241,0.05); border: none; border-left: 4px solid var(--accent); color: var(--text-primary); font-size: 0.85rem;">
                                            <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                            <div>Ten kontrahent istnieje już w systemie (NIP: <strong>@Model.ExtractedData.BuyerTaxId</strong>)</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning py-2 px-3 mb-3 d-flex align-items-center" style="background: rgba(245,158,11,0.05); border: none; border-left: 4px solid #f59e0b; color: var(--text-primary); font-size: 0.85rem;">
                                            <i class="bi bi-exclamation-triangle-fill text-warning me-2 fs-5"></i>
                                            <div>Brak kontrahenta w bazie danych. System poprosi o jego dodanie przed fakturą.</div>
                                        </div>
                                    }

                                    <div class="form-group mb-3">
                                        <label class="form-label text-muted small">Nazwa firmy / Nabywcy</label>
                                        <input name="BuyerName" value="@Model.ExtractedData.BuyerName" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="form-group mb-3">
                                        <label class="form-label text-muted small">NIP (Tax ID)</label>
                                        <input name="BuyerTaxId" value="@Model.ExtractedData.BuyerTaxId" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="form-group mb-3">
                                        <label class="form-label text-muted small">Adres pocztowy</label>
                                        <textarea name="BuyerAddress" class="form-control form-control-sm" rows="3">@Model.ExtractedData.BuyerAddress</textarea>
                                    </div>
                                </div>

                                <!-- Sekcja Faktury -->
                                <div class="col-md-6">
                                    <h5 class="fw-bold mb-3 border-bottom pb-2 text-secondary">
                                        <i class="bi bi-file-earmark-spreadsheet me-2"></i> Dane Faktury
                                    </h5>
                                    <div class="form-group mb-3">
                                        <label class="form-label text-muted small">Data wystawienia</label>
                                        <input name="Date" type="date" value="@Model.ExtractedData.Date.ToString("yyyy-MM-dd")" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="form-group mb-3">
                                        <label class="form-label text-muted small">Numer faktury (z dokumentu)</label>
                                        <input name="InvoiceNumber" value="@Model.ExtractedData.InvoiceNumber" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Pozycje Faktury -->
                            <div class="mt-4">
                                <h5 class="fw-bold mb-3 border-bottom pb-2 text-secondary">
                                    <i class="bi bi-list-task me-2"></i> Pozycje na fakturze
                                </h5>
                                <div class="table-responsive">
                                    <table class="dx-datagrid-table" style="width: 100%; min-width: 500px;">
                                        <thead class="dx-datagrid-headers">
                                            <tr class="dx-header-row">
                                                <th style="padding: 8px 12px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase;">Nazwa pozycji / usługi</th>
                                                <th style="padding: 8px 12px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; width: 100px;">Ilość</th>
                                                <th style="padding: 8px 12px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; width: 140px;">Cena netto</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.ExtractedData.Items.Count; i++)
                                            {
                                                var item = Model.ExtractedData.Items[i];
                                                <tr style="border-bottom: 1px solid var(--border);">
                                                    <td style="padding: 8px 12px;">
                                                        <input name="Items[@i].Name" value="@item.Name" class="form-control form-control-sm" required />
                                                    </td>
                                                    <td style="padding: 8px 12px;">
                                                        <input name="Items[@i].Quantity" type="number" step="0.01" value="@item.Quantity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" class="form-control form-control-sm text-end" required />
                                                    </td>
                                                    <td style="padding: 8px 12px;">
                                                        <input name="Items[@i].UnitPrice" type="number" step="0.01" value="@item.UnitPrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" class="form-control form-control-sm text-end" required />
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="text-end mt-4">
                                <button type="submit" class="btn-primary-accent py-2 px-4 justify-content-center">
                                    <i class="bi bi-file-earmark-plus me-2"></i>
                                    <span>Dodaj fakturę do systemu</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <div class="d-flex flex-wrap gap-2">
                <a href="@Url.Action("Proceed", "ImportInvoice", new { filePath = Model.FilePath })" class="btn btn-outline-primary py-2 px-4 d-inline-flex align-items-center justify-content-center">
                    <i class="bi bi-arrow-right-circle me-2"></i> Przejdź bez analizy (ręczne wprowadzanie)
                </a>
                <a href="@Url.Action("Index", "ImportInvoice")" class="btn btn-outline-secondary py-2 px-4 d-inline-flex align-items-center justify-content-center">
                    <i class="bi bi-arrow-counterclockwise me-2"></i> Wgraj inny dokument
                </a>
            </div>
        </div>
    }
</div>

<style>
    .upload-area {
        border: 2px dashed var(--border-strong);
        border-radius: 12px;
        padding: 32px 20px;
        text-align: center;
        transition: all 0.2s ease;
        position: relative;
        cursor: pointer;
        background: var(--accent-soft);
    }

    .upload-area:hover, .upload-area.drag-over {
        border-color: var(--accent);
        background: rgba(99, 102, 241, 0.08);
        transform: translateY(-1px);
    }

    .upload-area__input {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
    }

    .extracted-text-box {
        background-color: var(--bg-tertiary);
        border: 1px solid var(--border-default);
        border-radius: 8px;
        padding: 1rem;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--text-primary);
        max-height: 400px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
</style>

@section Scripts {
    @if (!Model.HasResult)
    {
        <script>
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const submitBtn = document.getElementById('submitBtn');
            const selectedFileDiv = document.querySelector('.selected-file');
            const fileNameDisplay = document.getElementById('fileName');
            const fileSizeDisplay = document.getElementById('fileSize');
            const removeFileBtn = document.getElementById('removeFile');
            const uploadIcon = document.querySelector('.upload-area__icon');
            const uploadText = document.querySelector('.upload-area__text');
            const uploadHint = document.querySelector('.upload-area__hint');

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => dropZone.classList.add('drag-over'), false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => dropZone.classList.remove('drag-over'), false);
            });

            fileInput.addEventListener('change', function (e) {
                handleFiles(this.files);
            });

            function handleFiles(files) {
                if (files.length > 0) {
                    const file = files[0];
                    fileNameDisplay.textContent = file.name;
                    fileSizeDisplay.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';

                    selectedFileDiv.classList.remove('d-none');
                    uploadIcon.classList.add('d-none');
                    uploadText.classList.add('d-none');
                    uploadHint.classList.add('d-none');
                    submitBtn.disabled = false;
                }
            }

            removeFileBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                fileInput.value = '';
                selectedFileDiv.classList.add('d-none');
                uploadIcon.classList.remove('d-none');
                uploadText.classList.remove('d-none');
                uploadHint.classList.remove('d-none');
                submitBtn.disabled = true;
            });

            document.getElementById('importForm').addEventListener('submit', function () {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Analizowanie...';
            });
        </script>
    }
    else
    {
        <script>
            document.getElementById('copyTextBtn').addEventListener('click', function () {
                const text = document.getElementById('extractedContent').innerText;
                navigator.clipboard.writeText(text);
                
                const btn = this;
                const icon = btn.querySelector('i');
                const oldClass = icon.className;
                icon.className = 'bi bi-check-lg text-success me-1';
                setTimeout(() => {
                    icon.className = oldClass;
                }, 2000);
            });

            document.getElementById('aiAnalysisForm').addEventListener('submit', function () {
                const btn = document.getElementById('aiAnalyzeBtn');
                const spinner = document.getElementById('aiSpinner');
                const icon = document.getElementById('aiMagicIcon');
                const btnText = document.getElementById('aiButtonText');

                btn.disabled = true;
                spinner.classList.remove('d-none');
                icon.classList.add('d-none');
                btnText.textContent = 'Analizowanie tekstu przez AI...';
            });
        </script>
    }
}
