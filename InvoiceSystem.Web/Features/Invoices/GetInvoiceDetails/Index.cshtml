@model InvoiceSystem.Web.Features.Invoices.GetInvoiceDetails.GetInvoiceDetailsViewModel
@{
    ViewData["Title"] = $"Faktura {Model.InvoiceNumber}";
}

<div class="page-body">
    <div class="invoice-actions-bar no-print">
        @if (Model.Status == InvoiceSystem.Web.Domain.Entities.InvoiceStatus.Draft)
        {
            <a href="/invoices/update/@Model.Id" class="btn-secondary-outline justify-content-center">
                <i class="bi bi-pencil"></i> Edytuj
            </a>
            <form asp-controller="ConfirmInvoice" asp-action="Confirm" asp-route-id="@Model.Id" method="post" class="actions-bar-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-primary-accent justify-content-center w-100">
                    <i class="bi bi-check-circle"></i> Zatwierdź
                </button>
            </form>
            <button type="button" class="btn-action-delete-large justify-content-center" onclick="showDeleteModal('@Model.Id', '@Model.InvoiceNumber')">
                <i class="bi bi-trash"></i> Usuń
            </button>
        }
        else if (Model.Status == InvoiceSystem.Web.Domain.Entities.InvoiceStatus.Confirmed)
        {
            <form asp-controller="MarkAsPaid" asp-action="Pay" asp-route-id="@Model.Id" method="post" class="actions-bar-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-primary-accent justify-content-center w-100">
                    <i class="bi bi-cash-coin"></i> Oznacz jako opłaconą
                </button>
            </form>
        }
        
        <button onclick="printInvoice()" class="btn-secondary-outline justify-content-center">
            <i class="bi bi-printer"></i> Drukuj
        </button>
        <a href="/invoices" class="btn-primary-accent justify-content-center">
            <i class="bi bi-arrow-left"></i> Powrót
        </a>
    </div>

    <!-- Zoom Hint Banner for Mobile -->
    <div class="zoom-banner no-print d-md-none text-center mb-3">
        <i class="bi bi-zoom-in me-1"></i> Dotknij faktury, aby ją powiększyć / zmniejszyć
    </div>

    <div class="invoice-miniature-wrapper no-print-wrapper" id="invoiceWrapper">
        <div class="invoice-document shadow-lg" id="invoiceDoc">
            <div class="invoice-content-wrap">
                <!-- Header -->
                <div class="d-flex justify-content-between mb-5">
                    <div>
                        <h2 class="invoice-logo">Invoice<span>System</span></h2>
                        <p class="text-muted small">System Zarządzania Fakturami</p>
                    </div>
                    <div class="text-end">
                        <h1 class="h3 mb-0">FAKTURA</h1>
                        <p class="fw-bold d-flex align-items-center justify-content-end gap-2">
                            Nr: @Model.InvoiceNumber
                            @if (Model.Status == InvoiceSystem.Web.Domain.Entities.InvoiceStatus.Draft)
                            {
                                <span class="badge-status badge-status--draft">Szkic</span>
                            }
                            else if (Model.Status == InvoiceSystem.Web.Domain.Entities.InvoiceStatus.Confirmed)
                            {
                                <span class="badge-status badge-status--overdue">Zatwierdzona</span>
                            }
                            else if (Model.Status == InvoiceSystem.Web.Domain.Entities.InvoiceStatus.Paid)
                            {
                                <span class="badge-status badge-status--confirmed">Opłacona</span>
                            }
                        </p>
                        <p class="small text-muted">Data wystawienia: @Model.Date.ToShortDateString()</p>
                    </div>
                </div>

            <hr class="my-4" />

            <!-- Contractor Info -->
            <div class="row mb-4">
                <div class="col-6">
                    <label class="text-muted small text-uppercase fw-bold d-block mb-2">Sprzedawca</label>
                    <strong>InvoiceSystem Enterprise</strong><br />
                    ul. Technologiczna 12<br />
                    80-001 Gdańsk<br />
                    NIP: 1234567890
                </div>
                <div class="col-6 text-end">
                    <label class="text-muted small text-uppercase fw-bold d-block mb-2">Nabywca</label>
                    <strong>@Model.Contractor.Name</strong><br />
                    @Model.Contractor.Address<br />
                    NIP: @Model.Contractor.TaxId
                </div>
            </div>

            <!-- Items Table -->
            <div class="table-responsive mb-4">
                <table class="table table-bordered mb-0" style="min-width: 600px;">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">Lp.</th>
                            <th>Nazwa towaru lub usługi</th>
                            <th class="text-end" style="width: 100px;">Ilość</th>
                            <th class="text-end" style="width: 150px;">Cena netto</th>
                            <th class="text-end" style="width: 150px;">Wartość netto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@item.Name</td>
                                <td class="text-end">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") PLN</td>
                                <td class="text-end">@item.TotalPrice.ToString("N2") PLN</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Summary -->
            <div class="row justify-content-end">
                <div class="col-6">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Suma netto:</span>
                        <strong>@Model.TotalAmount.ToString("N2") PLN</strong>
                    </div>
                    <div class="d-flex justify-content-between py-3">
                        <span class="h5 m-0">RAZEM:</span>
                        <span class="h5 fw-bold m-0 text-primary">@Model.TotalAmount.ToString("N2") PLN</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="invoice-footer">
            Faktura wygenerowana automatycznie w systemie InvoiceSystem. Dziękujemy!
        </div>
    </div>
</div>
</div>

@await Html.PartialAsync("Components/_DeleteModal")

<style>
    .invoice-actions-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 1.5rem;
    }
    
    .invoice-actions-bar a,
    .invoice-actions-bar button,
    .invoice-actions-bar .actions-bar-form {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .invoice-actions-bar .actions-bar-form {
        margin: 0;
        padding: 0;
        border: none;
    }

    .zoom-banner {
        font-size: 0.8rem;
        color: var(--accent);
        background-color: var(--accent-soft);
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px dashed rgba(99, 102, 241, 0.25);
    }

    /* Wrapper that clips the miniature on mobile */
    .invoice-miniature-wrapper {
        width: 100%;
        overflow: hidden;
    }

    .invoice-document {
        background: white !important;
        color: #1a1a1a !important;
        padding: 4rem;
        border-radius: 8px;
        width: 800px;
        max-width: 800px;
        margin: 1rem auto;
        font-family: 'Inter', sans-serif;
        display: flex;
        flex-direction: column;
        min-height: 1130px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15) !important;
        transform-origin: top left;
        
        /* Reset Bootstrap 5 table variables locally for dark mode overrides */
        --bs-table-bg: transparent !important;
        --bs-table-color: #1a1a1a !important;
        --bs-table-border-color: #dee2e6 !important;
        --bs-table-striped-color: #1a1a1a !important;
        --bs-table-striped-bg: transparent !important;
        --bs-table-active-bg: transparent !important;
        --bs-table-hover-bg: transparent !important;
    }
    
    @@media (max-width: 767px) {
        .invoice-actions-bar {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 8px;
        }
        .invoice-actions-bar a,
        .invoice-actions-bar button,
        .invoice-actions-bar .actions-bar-form {
            flex: 1 1 calc(50% - 4px);
            min-width: calc(50% - 4px);
            width: auto !important;
        }
        .invoice-actions-bar .actions-bar-form button {
            width: 100% !important;
        }

        /* Po kliknięciu - pełny rozmiar z przewijaniem */
        .invoice-miniature-wrapper.zoomed {
            overflow-x: auto;
        }
    }
    
    @@media (min-width: 768px) {
        .invoice-document {
            margin: 2rem auto;
            min-height: 297mm;
        }
    }
    
    .invoice-content-wrap { flex: 1; }

    .invoice-document table,
    .invoice-document table tr,
    .invoice-document table td,
    .invoice-document table th { 
        background-color: transparent !important; 
        color: #1a1a1a !important; 
        border-color: #dee2e6 !important; 
    }

    .invoice-footer {
        margin-top: 3rem;
        padding-top: 2rem;
        text-align: center;
        color: #9ca3af;
        font-size: 0.75rem;
        border-top: 1px solid #f3f4f6;
    }
    
    .invoice-logo { font-weight: 800; letter-spacing: -1px; margin: 0; color: #1a1a1a; }
    .invoice-logo span { color: #6366f1; }

    .btn-action-delete-large {
        background: rgba(239, 68, 68, 0.05);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .btn-action-delete-large:hover { background: #ef4444; color: white; transform: translateY(-1px); }

    /* PRINT ENGINE */
    @@media print {
        @@page {
            margin: 15mm;
            size: A4;
        }

        html, body {
            background: white !important;
            height: auto !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow: hidden !important; /* Usuwa suwaki na wydruku */
        }

        .no-print, .no-print-wrapper, .zoom-banner, .app-topbar, .app-sidebar, .page-header, .page-header-actions, .modal-backdrop {
            display: none !important;
        }

        .invoice-miniature-wrapper {
            overflow: visible !important;
            width: 100% !important;
        }
        .invoice-miniature-wrapper .invoice-document {
            transform: none !important;
            margin-bottom: 0 !important;
        }

        .app-wrapper, .app-content, .content-body, .page-body {
            background: white !important;
            padding: 0 !important;
            margin: 0 !important;
            display: block !important;
            height: auto !important;
            width: 100% !important;
            overflow: hidden !important; /* Blokada suwaków na każdym poziomie */
        }

        .invoice-document {
            box-shadow: none !important;
            padding: 0 !important;
            margin: 0 !important;
            width: 100% !important;
            border: none !important;
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important; /* Tu też blokujemy */
        }

        .invoice-footer {
            margin-top: auto !important;
            padding-bottom: 2mm; /* Mniejszy padding dla pewności */
            border-top: 1px solid #eee;
            text-align: center;
        }

        tr {
            page-break-inside: avoid !important;
            break-inside: avoid !important;
        }
    }

    /* Blur UI elements when printing */
    .is-printing .app-topbar,
    .is-printing .app-sidebar,
    .is-printing .page-header {
        filter: blur(8px);
        opacity: 0.6;
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <script>
        function printInvoice() {
            const doc = document.getElementById('invoiceDoc');
            doc.style.minHeight = 'auto';
            const safetyBufferMm = 264;
            const pxToMm = 0.2645833333;
            const currentHeightMm = doc.scrollHeight * pxToMm;
            const pagesCount = Math.ceil(currentHeightMm / safetyBufferMm);
            doc.style.minHeight = (pagesCount * safetyBufferMm) + 'mm';
            document.body.classList.add('is-printing');
            setTimeout(() => {
                window.print();
                document.body.classList.remove('is-printing');
                doc.style.minHeight = '297mm';
            }, 300);
        }

        // ---- Miniatura: dynamiczne skalowanie faktury A4 do ekranu ----
        const wrapper = document.getElementById('invoiceWrapper');
        const invoiceDoc = document.getElementById('invoiceDoc');
        const INVOICE_WIDTH = 800;
        const SIDE_PADDING = 16;

        function scaleInvoice() {
            if (!wrapper || !invoiceDoc) return;

            // Na desktopie (>=768px) nie skalujemy
            if (window.innerWidth >= 768) {
                invoiceDoc.style.transform = '';
                wrapper.style.height = '';
                wrapper.style.cursor = '';
                return;
            }

            // Jeśli w trybie zoom - pełny rozmiar 1:1
            if (wrapper.classList.contains('zoomed')) {
                invoiceDoc.style.transform = 'scale(1)';
                wrapper.style.height = '';
                wrapper.style.cursor = 'zoom-out';
                return;
            }

            // Oblicz skalę: dostępna szerokość / szerokość faktury
            var availableWidth = wrapper.clientWidth - SIDE_PADDING;
            var scale = Math.min(availableWidth / INVOICE_WIDTH, 1);
            invoiceDoc.style.transform = 'scale(' + scale + ')';

            // Ustaw wysokość wrappera = skalowana wysokość faktury
            wrapper.style.height = (invoiceDoc.scrollHeight * scale) + 'px';
            wrapper.style.cursor = 'zoom-in';
        }

        // Zoom toggle po kliknięciu
        if (wrapper) {
            wrapper.addEventListener('click', function() {
                if (window.innerWidth >= 768) return;
                this.classList.toggle('zoomed');
                scaleInvoice();
            });
        }

        // Skaluj na starcie i przy resize
        scaleInvoice();
        window.addEventListener('resize', scaleInvoice);
    </script>
}
