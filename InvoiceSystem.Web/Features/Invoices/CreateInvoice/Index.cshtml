@using InvoiceSystem.Web.Features.Invoices.CreateInvoice
@model CreateInvoiceViewModel
@{
    ViewData["Title"] = "Nowa Faktura";
}


<div class="page-body">
    <form asp-action="Index" method="post" id="invoiceForm">
        @Html.AntiForgeryToken()
        
        <div class="row">
            <!-- Nagłówek Faktury -->
            <div class="col-lg-4">
                <div class="data-card mb-4">
                    <div class="data-card__header">
                        <h3 class="data-card__title">Dane podstawowe</h3>
                    </div>
                    <div class="data-card__body">
                        <div class="form-group mb-3">
                            <label class="form-label">Kontrahent</label>
                            <select name="Command.ContractorId" class="form-select @(ViewData.ModelState["Command.ContractorId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                <option value="">-- Wybierz kontrahenta --</option>
                                @foreach(var c in Model.Contractors)
                                {
                                    <option value="@c.Id" selected="@(Model.Command.ContractorId == c.Id ? "selected" : null)">@c.Name</option>
                                }
                            </select>
                            <span class="text-danger small">@Html.ValidationMessage("Command.ContractorId")</span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Numer faktury</label>
                            <input class="form-control" readonly placeholder="Nadany automatycznie" style="opacity: 0.6; cursor: not-allowed;" />
                        </div>

                        <div class="form-group mb-0">
                            <label class="form-label">Data wystawienia</label>
                            <input name="Command.Date" type="date" value="@Model.Command.Date.ToString("yyyy-MM-dd")" class="form-control @(ViewData.ModelState["Command.Date"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <span class="text-danger small">@Html.ValidationMessage("Command.Date")</span>
                        </div>
                    </div>
                </div>
                
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                {
                    <div class="alert alert-danger d-flex align-items-center mb-4" style="background: rgba(239,68,68,0.1); border: none; border-left: 4px solid #ef4444; color: #ef4444;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div asp-validation-summary="ModelOnly" class="small"></div>
                    </div>
                }

                <div class="d-flex gap-2 mb-4 mb-lg-0">
                    <button type="submit" class="btn-primary-accent flex-grow-1 justify-content-center py-2">
                        <i class="bi bi-check-circle me-1"></i> Wystaw fakturę
                    </button>
                    <a href="/invoices" class="btn-secondary-outline justify-content-center py-2 px-3">
                        <i class="bi bi-x-circle me-1"></i> Anuluj
                    </a>
                </div>
            </div>

            <!-- Pozycje Faktury -->
            <div class="col-lg-8">
                <div class="data-card">
                    <div class="data-card__header">
                        <h3 class="data-card__title">Pozycje faktury</h3>
                        <button type="button" class="btn-secondary-outline btn-sm" onclick="addItem()">
                            <i class="bi bi-plus-lg me-1"></i>
                            <span>Dodaj pozycję</span>
                        </button>
                    </div>

                    <div class="data-card__body p-0">
                        <div class="table-responsive">
                            <table class="dx-datagrid-table" style="width: 100%; min-width: 650px;">
                                <thead class="dx-datagrid-headers">
                                    <tr class="dx-header-row">
                                        <th style="padding: 12px 16px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Nazwa produktu / usługi</th>
                                        <th style="padding: 12px 16px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; width: 120px;">Ilość</th>
                                        <th style="padding: 12px 16px; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; width: 160px;">Cena netto</th>
                                        <th style="padding: 12px 16px; width: 60px;"></th>
                                    </tr>
                                </thead>
                                <tbody id="itemsContainer">
                                    @if (Model.Command.Items.Count > 0)
                                    {
                                        for (int i = 0; i < Model.Command.Items.Count; i++)
                                        {
                                            <tr class="item-row" style="border-bottom: 1px solid var(--border);">
                                                <td style="padding: 12px 16px;">
                                                    <input name="Command.Items[@i].Name" value="@Model.Command.Items[i].Name" class="form-control @(ViewData.ModelState[$"Command.Items[{i}].Name"]?.Errors.Count > 0 ? "is-invalid" : "")" placeholder="Opis pozycji..." />
                                                    <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].Name")</span>
                                                </td>
                                                <td style="padding: 12px 16px;">
                                                    <input name="Command.Items[@i].Quantity" type="number" step="1" min="1" value="@Model.Command.Items[i].Quantity" class="form-control text-end @(ViewData.ModelState[$"Command.Items[{i}].Quantity"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                                    <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].Quantity")</span>
                                                </td>
                                                <td style="padding: 12px 16px;">
                                                    <input name="Command.Items[@i].UnitPrice" type="number" step="0.01" value="@Model.Command.Items[i].UnitPrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" class="form-control text-end @(ViewData.ModelState[$"Command.Items[{i}].UnitPrice"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                                    <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].UnitPrice")</span>
                                                </td>
                                                <td style="padding: 12px 16px; text-align: center;">
                                                    <button type="button" class="btn-action btn-action-delete" onclick="removeItem(this)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let itemIndex = @Model.Command.Items.Count;

        function addItem() {
            const container = document.getElementById('itemsContainer');
            const row = document.createElement('tr');
            row.className = 'item-row';
            row.style.borderBottom = '1px solid var(--border)';
            row.innerHTML = `
                <td style="padding: 12px 16px;">
                    <input name="Command.Items[${itemIndex}].Name" class="form-control" placeholder="Opis pozycji..." required />
                </td>
                <td style="padding: 12px 16px;">
                    <input name="Command.Items[${itemIndex}].Quantity" type="number" step="1" min="1" value="1" class="form-control text-end" required />
                </td>
                <td style="padding: 12px 16px;">
                    <input name="Command.Items[${itemIndex}].UnitPrice" type="number" step="0.01" value="0.00" class="form-control text-end" required />
                </td>
                <td style="padding: 12px 16px; text-align: center;">
                    <button type="button" class="btn-action btn-action-delete" onclick="removeItem(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;
            container.appendChild(row);
            itemIndex++;
        }

        function removeItem(btn) {
            const row = btn.closest('tr');
            row.remove();
        }

        if (itemIndex === 0) {
            addItem();
        }
    </script>
}
