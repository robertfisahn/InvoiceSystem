@using InvoiceSystem.Web.Features.Invoices.GetInvoiceList
@model List<GetInvoiceListViewModel>

@{
    ViewData["Title"] = "Faktury";
}


<div class="page-body">
    <div class="data-card p-0">
        <!-- Toolbar: Search & Info -->
        <div class="data-card__header d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-sm-center p-3">
            <div class="search-box w-100 w-sm-auto" style="max-width: 300px;">
                <i class="bi bi-search"></i>
                <input type="text" id="tableSearch" placeholder="Szukaj faktury..." class="form-control form-control-sm">
            </div>
            <div class="d-flex align-items-center justify-content-between justify-content-sm-end gap-3 w-100 w-sm-auto">
                <div class="d-flex align-items-center gap-2">
                    <label class="small text-secondary mb-0">Pokaż:</label>
                    <select id="pageSize" class="form-select form-select-sm" style="width: 70px; background-color: var(--bg-tertiary);">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="30">30</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="dx-datagrid-table" id="invoicesTable" style="width: 100%; border-collapse: collapse;">
                <thead class="dx-datagrid-headers">
                    <tr class="dx-header-row">
                        <th class="sortable" data-sort="number">Numer <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable" data-sort="contractor">Kontrahent <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable" data-sort="date">Data <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable text-end" data-sort="amount">Suma <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="dx-header-static text-center" style="width: 140px;">Akcje</th>
                    </tr>
                </thead>
                <tbody class="dx-datagrid-rows" id="tableBody">
                    @foreach (var invoice in Model)
                    {
                        <tr class="dx-row invoice-row" 
                            data-number="@invoice.InvoiceNumber"
                            data-contractor="@invoice.ContractorName"
                            data-date="@invoice.Date.ToString("yyyy-MM-dd")"
                            data-amount="@invoice.TotalAmount.ToString("F2").Replace(",", ".")">
                            <td style="padding: 14px 16px; font-weight: 600; color: var(--text-primary);">@invoice.InvoiceNumber</td>
                            <td style="padding: 14px 16px; color: var(--text-secondary);">@invoice.ContractorName</td>
                            <td style="padding: 14px 16px; color: var(--text-secondary);">@invoice.Date.ToShortDateString()</td>
                            <td style="padding: 14px 16px; text-align: right; font-weight: 700; color: var(--text-primary);">@invoice.TotalAmount.ToString("C")</td>
                            <td style="padding: 14px 16px; text-align: center;">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="/invoices/@invoice.Id" class="btn-action btn-action-view" title="Szczegóły">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/invoices/update/@invoice.Id" class="btn-action btn-action-edit" title="Edytuj">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn-action btn-action-delete" 
                                            onclick="showDeleteModal('@invoice.Id', '@invoice.InvoiceNumber')" title="Usuń">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Paginacja Info & Numbers -->
        <div class="p-3 d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-center" style="background: var(--bg-tertiary); border-top: 1px solid var(--border);">
            <div id="paginationInfo" style="font-size: 0.8rem; color: var(--text-secondary); text-align: center;">Ładowanie...</div>
            <div class="d-flex align-items-center justify-content-center gap-2">
                <button id="prevPage" class="btn-secondary-outline btn-sm px-2"><i class="bi bi-chevron-left"></i></button>
                <div id="paginationNumbers" class="d-flex gap-1"></div>
                <button id="nextPage" class="btn-secondary-outline btn-sm px-2"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Usuwania (Shared Component) -->
@await Html.PartialAsync("Components/_DeleteModal")

<style>
    .sortable, .dx-header-static { 
        padding: 12px 16px; 
        text-align: left; 
        color: var(--text-secondary); 
        font-size: 11px; 
        text-transform: uppercase; 
        letter-spacing: 0.05em; 
        border-bottom: 1px solid var(--border); 
        transition: color 0.2s; 
        white-space: nowrap; 
    }
    .sortable { cursor: pointer; }
    .sortable:hover { color: var(--accent); }
    .sortable i { opacity: 0.3; transition: opacity 0.2s; }
    .sortable.active i { opacity: 1; color: var(--accent); }
    .search-box { position: relative; width: 300px; }
    .search-box i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem; }
    .search-box input { padding-left: 32px !important; background-color: var(--bg-tertiary) !important; border-color: var(--border-strong) !important; }
    .invoice-row:hover { background-color: rgba(255, 255, 255, 0.02) !important; }
    .btn-action { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; border-radius: 6px; background: rgba(255, 255, 255, 0.03); color: var(--text-secondary); border: 1px solid var(--border); transition: all 0.2s; cursor: pointer; }
    .btn-action:hover { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }
    .btn-action-delete:hover { background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: rgba(239, 68, 68, 0.2); }

    /* Page Numbers Style */
    .page-number {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-secondary);
        transition: all 0.2s;
    }
    .page-number:hover {
        border-color: var(--accent);
        color: var(--accent);
    }
    .page-number.active {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
    }
</style>

@section Scripts {
    <script>
        $(function() {
            let currentPage = 1;
            let pageSize = parseInt($('#pageSize').val());
            let sortColumn = 'date';
            let sortOrder = 'desc';

            function updateTable() {
                let $allRows = $('.invoice-row');
                let $rowsArray = $allRows.get();
                const searchTerm = $('#tableSearch').val().toLowerCase();

                // 1. Sortowanie
                $rowsArray.sort(function(a, b) {
                    let valA = $(a).data(sortColumn);
                    let valB = $(b).data(sortColumn);
                    if (sortColumn === 'amount' || sortColumn === 'date') return sortOrder === 'asc' ? (valA > valB ? 1 : -1) : (valB > valA ? 1 : -1);
                    return sortOrder === 'asc' ? valA.toString().localeCompare(valB.toString()) : valB.toString().localeCompare(valA.toString());
                });

                const $body = $('#tableBody');
                $.each($rowsArray, function(index, row) { $body.append(row); });

                // 2. Filtrowanie
                const $filteredRows = $('.invoice-row').filter(function() { 
                    return $(this).text().toLowerCase().indexOf(searchTerm) > -1; 
                });

                const totalItems = $filteredRows.length;
                const totalPages = Math.ceil(totalItems / pageSize);
                
                if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

                $allRows.hide();
                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;
                $filteredRows.slice(start, end).show();

                // 3. Renderowanie numerów stron
                const $numbersWrap = $('#paginationNumbers');
                $numbersWrap.empty();
                
                for (let i = 1; i <= totalPages; i++) {
                    const $btn = $('<button></button>')
                        .addClass('page-number')
                        .text(i)
                        .toggleClass('active', i === currentPage)
                        .on('click', function() {
                            currentPage = i;
                            updateTable();
                        });
                    $numbersWrap.append($btn);
                }

                const showStart = totalItems === 0 ? 0 : start + 1;
                const showEnd = Math.min(end, totalItems);
                $('#paginationInfo').html(`Pokazano <strong>${showStart}-${showEnd}</strong> z <strong>${totalItems}</strong> faktur`);
                
                $('#prevPage').prop('disabled', currentPage === 1);
                $('#nextPage').prop('disabled', currentPage >= totalPages || totalPages === 0);
            }

            $('.sortable').on('click', function() {
                const column = $(this).data('sort');
                if (sortColumn === column) sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
                else { sortColumn = column; sortOrder = 'asc'; }
                $('.sortable').removeClass('active').find('i').attr('class', 'bi bi-arrow-down-up');
                $(this).addClass('active').find('i').attr('class', sortOrder === 'asc' ? 'bi bi-sort-up' : 'bi bi-sort-down');
                updateTable();
            });

            $('#tableSearch').on('input', function() { currentPage = 1; updateTable(); });
            $('#pageSize').on('change', function() { pageSize = parseInt($(this).val()); currentPage = 1; updateTable(); });
            $('#prevPage').on('click', function() { if (currentPage > 1) { currentPage--; updateTable(); } });
            $('#nextPage').on('click', function() { 
                const searchTerm = $('#tableSearch').val().toLowerCase();
                const totalItems = $('.invoice-row').filter(function() { return $(this).text().toLowerCase().indexOf(searchTerm) > -1; }).length;
                if (currentPage < Math.ceil(totalItems / pageSize)) { currentPage++; updateTable(); } 
            });

            $('.sortable[data-sort="date"]').addClass('active').find('i').attr('class', 'bi bi-sort-down');
            updateTable();
        });
    </script>
}
