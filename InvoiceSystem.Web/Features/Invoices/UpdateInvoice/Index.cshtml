@using InvoiceSystem.Web.Features.Invoices.UpdateInvoice
@model UpdateInvoiceViewModel
@{
    ViewData["Title"] = "Edytuj Fakturę";
}

<div class="page">
    <div class="page__header">
        <div>
            <h1 class="page__title">Edytuj Fakturę</h1>
            <p class="page__subtitle">Zaktualizuj dane dokumentu: @Model.Command.InvoiceNumber</p>
        </div>
        <a href="/invoices/@Model.Id" class="btn btn-outline-secondary btn-sm">Anuluj</a>
    </div>

    <form asp-action="Index" asp-route-id="@Model.Id" method="post" id="invoiceForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Command.Id" value="@Model.Id" />
        
        <div class="row">
            <!-- Nagłówek Faktury -->
            <div class="col-md-4">
                <div class="data-card mb-4">
                    <div class="section-header">
                        <h3 class="section-header__title">Dane podstawowe</h3>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Kontrahent</label>
                        <select name="Command.ContractorId" class="form-control @(ViewData.ModelState["Command.ContractorId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                            <option value="">-- Wybierz kontrahenta --</option>
                            @foreach(var c in Model.Contractors)
                            {
                                <option value="@c.Id" selected="@(Model.Command.ContractorId == c.Id ? "selected" : null)">@c.Name</option>
                            }
                        </select>
                        <span class="text-danger small">@Html.ValidationMessage("Command.ContractorId")</span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Numer faktury</label>
                        <input name="Command.InvoiceNumber" value="@Model.Command.InvoiceNumber" class="form-control @(ViewData.ModelState["Command.InvoiceNumber"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span class="text-danger small">@Html.ValidationMessage("Command.InvoiceNumber")</span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Data wystawienia</label>
                        <input name="Command.Date" type="date" value="@Model.Command.Date.ToString("yyyy-MM-dd")" class="form-control @(ViewData.ModelState["Command.Date"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span class="text-danger small">@Html.ValidationMessage("Command.Date")</span>
                    </div>
                </div>
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    Zapisz zmiany
                </button>
            </div>

            <!-- Pozycje Faktury -->
            <div class="col-md-8">
                <div class="data-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="section-header__title m-0">Pozycje faktury</h3>
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addItem()">
                            + Dodaj pozycję
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="invoice-table" id="itemsTable">
                            <thead>
                                <tr>
                                    <th>Nazwa produktu / usługi</th>
                                    <th style="width: 120px;">Ilość</th>
                                    <th style="width: 160px;">Cena netto</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsContainer">
                                @for (int i = 0; i < Model.Command.Items.Count; i++)
                                {
                                    <tr class="item-row">
                                        <td>
                                            <input type="hidden" name="Command.Items[@i].Id" value="@Model.Command.Items[i].Id" />
                                            <input name="Command.Items[@i].Name" value="@Model.Command.Items[i].Name" class="form-control @(ViewData.ModelState[$"Command.Items[{i}].Name"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                            <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].Name")</span>
                                        </td>
                                        <td>
                                            <input name="Command.Items[@i].Quantity" type="number" step="0.01" value="@Model.Command.Items[i].Quantity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" class="form-control @(ViewData.ModelState[$"Command.Items[{i}].Quantity"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                            <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].Quantity")</span>
                                        </td>
                                        <td>
                                            <input name="Command.Items[@i].UnitPrice" type="number" step="0.01" value="@Model.Command.Items[i].UnitPrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" class="form-control @(ViewData.ModelState[$"Command.Items[{i}].UnitPrice"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                            <span class="text-danger small">@Html.ValidationMessage($"Command.Items[{i}].UnitPrice")</span>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-link text-danger p-0" onclick="removeItem(this)" title="Usuń pozycję">
                                                &times;
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let itemIndex = @Model.Command.Items.Count;

        function addItem() {
            const container = document.getElementById('itemsContainer');
            const row = document.createElement('tr');
            row.className = 'item-row';
            row.innerHTML = `
                <td>
                    <input type="hidden" name="Command.Items[${itemIndex}].Id" value="" />
                    <input name="Command.Items[${itemIndex}].Name" class="form-control" placeholder="Nazwa usługi..." required />
                </td>
                <td>
                    <input name="Command.Items[${itemIndex}].Quantity" type="number" step="0.01" value="1.00" class="form-control" required />
                </td>
                <td>
                    <input name="Command.Items[${itemIndex}].UnitPrice" type="number" step="0.01" value="0.00" class="form-control" required />
                </td>
                <td>
                    <button type="button" class="btn btn-link text-danger p-0" onclick="removeItem(this)">
                        &times;
                    </button>
                </td>
            `;
            container.appendChild(row);
            itemIndex++;
        }

        function removeItem(btn) {
            const row = btn.closest('tr');
            row.remove();
        }
    </script>
}
