@model InvoiceSystem.Web.Features.Auth.Login.LoginCommand
@{
    ViewData["Title"] = "Logowanie";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvoiceSystem</title>

    <script src="~/js/theme.js" asp-append-version="true"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- App CSS -->
    <link rel="stylesheet" href="~/css/frontend-variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    <style>
        :root {
            --login-bg: var(--color-bg-primary);
            --card-bg: var(--color-bg-secondary);
            --input-bg: var(--color-bg-tertiary);
            --primary: var(--color-primary);
            --text: var(--color-text-primary);
            --text-muted: var(--color-text-secondary);
        }

        body {
            background-color: var(--login-bg);
            font-family: 'Inter', sans-serif;
            color: var(--text);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
        }

        .login-card {
            background: var(--card-bg);
            border-radius: 1.25rem;
            padding: 2.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .login-logo {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: var(--text);
            text-decoration: none;
            display: block;
            margin-bottom: 0.5rem;
        }

        .login-logo span {
            color: var(--primary);
        }

        .login-subtitle {
            color: var(--text-muted);
            font-size: 0.9375rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .form-control {
            background: var(--input-bg);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background: var(--input-bg);
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.15);
            color: var(--text);
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            border-radius: 0.75rem;
            padding: 0.75rem;
            font-weight: 600;
            width: 100%;
            margin-top: 1rem;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: var(--color-primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(var(--color-primary-rgb), 0.3);
        }

        .login-footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .alert-danger {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
        }

        /* Test credentials box */
        .test-credentials {
            margin-top: 2rem;
            padding: 1rem;
            background: rgba(var(--color-primary-rgb), 0.05);
            border-radius: 0.75rem;
            font-size: 0.8125rem;
            border: 1px dashed rgba(var(--color-primary-rgb), 0.2);
        }

        .test-credentials code {
            color: var(--primary);
            font-family: 'JetBrains Mono', monospace;
        }
    </style>
</head>
<body>

    <div class="theme-toggle-container" style="position: absolute; top: 1.5rem; right: 1.5rem;">
        <button id="theme-toggle-btn" 
                class="btn btn-outline-secondary btn-sm" 
                onclick="toggleTheme()"
                title="Przełącz motyw">
            ☀️
        </button>
    </div>

    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <a href="/" class="login-logo">Invoice<span>System</span></a>
                <p class="login-subtitle">Zaloguj się do panelu zarządzania</p>
            </div>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="form-group">
                    <label asp-for="Username" class="form-label">Użytkownik</label>
                    <input asp-for="Username" class="form-control" placeholder="admin" autofocus />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Hasło</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small text-muted">Zapamiętaj mnie</label>
                </div>

                <button type="submit" class="btn btn-primary">Zaloguj się</button>
            </form>

            <div class="test-credentials">
                <strong>Dane testowe:</strong><br />
                User: <code>admin</code><br />
                Pass: <code>Admin123!</code>
            </div>
        </div>

        <div class="login-footer">
            &copy; 2026 InvoiceSystem &mdash; System Zarządzania Fakturami
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
