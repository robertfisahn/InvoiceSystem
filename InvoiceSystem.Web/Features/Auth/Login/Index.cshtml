@model InvoiceSystem.Web.Features.Auth.Login.LoginCommand
@{
    ViewData["Title"] = "Logowanie";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvoiceSystem</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- App Styles -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    
    <style>
        :root {
            --primary-purple: #6366f1;
            --primary-purple-hover: #4f46e5;
        }

        body {
            background: radial-gradient(circle at top right, var(--bg-secondary), var(--bg-primary));
            font-family: 'Inter', sans-serif;
            color: var(--text-primary);
            min-height: 100vh; /* Zmiana z height na min-height */
            margin: 0;
            display: flex;
            flex-direction: column;
            overflow-y: auto; /* Pozwól na scroll gdy treść się nie mieści */
        }

        .login-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem; /* Więcej oddechu */
        }

        .login-card {
            background: var(--bg-primary);
            border-radius: 1.5rem;
            padding: 2.5rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid var(--border);
            animation: fadeIn 0.6s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-logo {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: var(--text-primary);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 0.25rem;
        }

        .logo-box {
            background: var(--primary-purple);
            color: white;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .login-logo span { color: var(--primary-purple); }

        .login-subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 0.4rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-control {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

        .form-control:focus {
            background: var(--bg-secondary);
            border-color: var(--primary-purple);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            color: var(--text-primary);
        }

        .btn-login {
            background: var(--primary-purple);
            border: none;
            color: white;
            border-radius: 0.75rem;
            padding: 0.85rem;
            font-weight: 700;
            width: 100%;
            margin-top: 1rem;
            transition: all 0.2s;
        }

        .btn-login:hover {
            background: var(--primary-purple-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
        }

        .test-credentials {
            margin-top: 1.5rem;
            padding: 1rem;
            background: var(--bg-secondary);
            border-radius: 1rem;
            font-size: 0.8rem;
            border: 1px solid var(--border);
        }

        .test-credentials code {
            color: var(--primary-purple);
            font-weight: 700;
        }

        .login-footer {
            padding: 1.5rem;
            text-align: center;
            font-size: 0.75rem;
            color: var(--text-secondary);
            opacity: 0.6;
        }

        #themeToggle {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .alert-modern-danger {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-left: 4px solid #ef4444;
            color: #ef4444;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.8rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-modern-danger ul {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .alert-modern-danger li {
            margin: 0;
        }
    </style>
</head>
<body>

    <button id="themeToggle" title="Zmień motyw">
        <i class="bi bi-brightness-high" id="themeIcon"></i>
    </button>

    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <div class="logo-box">IS</div>
                    Invoice<span>System</span>
                </div>
                <p class="login-subtitle">Zaloguj się do systemu.</p>
            </div>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                @{
                    var hasModelErrors = ViewData.ModelState != null && 
                                        ViewData.ModelState.ContainsKey(string.Empty) && 
                                        ViewData.ModelState[string.Empty]?.Errors.Any() == true;
                }

                @if (hasModelErrors)
                {
                    <div class="alert-modern-danger">
                        <i class="bi bi-exclamation-circle"></i>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Użytkownik</label>
                    <input asp-for="Username" class="form-control" placeholder="Wpisz login..." autofocus />
                    <span asp-validation-for="Username" style="color: #ef4444; font-size: 0.75rem;" class="mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Hasło</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" style="color: #ef4444; font-size: 0.75rem;" class="mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-login">ZALOGUJ SIĘ</button>
            </form>

            <div class="test-credentials text-center">
                <span class="text-secondary">Demo:</span> <code>admin</code> / <code>Admin123!</code>
            </div>
        </div>
    </div>

    <div class="login-footer">
        &copy; 2026 InvoiceSystem &mdash; Enterprise Management Platform
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
</body>
</html>
