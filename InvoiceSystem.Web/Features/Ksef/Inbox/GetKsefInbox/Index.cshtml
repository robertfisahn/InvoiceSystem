@using InvoiceSystem.Web.Domain.Entities
@model List<KsefIncomingInvoice>
@{
    ViewData["Title"] = "Skrzynka KSeF";
    bool ksefEnabled = ViewBag.KsefEnabled;
    bool ksefConfigured = ViewBag.KsefConfigured;
}

<div class="page-body">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <!-- Panel Sterowania Synchronizacją -->
    <div class="data-card mb-4">
        <div class="data-card__body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h4 class="mb-1 fw-bold"><i class="bi bi-cloud-download me-2 text-primary"></i>Status skrzynki odbiorczej</h4>
                @if (ksefEnabled && ksefConfigured)
                {
                    <p class="text-muted mb-0 small">
                        Automatyczna synchronizacja w tle jest aktywna. Pobierane są faktury kosztowe, w których Twoja firma jest nabywcą.
                    </p>
                }
                else
                {
                    <p class="text-danger mb-0 small">
                        <i class="bi bi-exclamation-circle me-1"></i> Integracja KSeF jest wyłączona lub nieskonfigurowana. Skonfiguruj NIP i Token w zakładce Konfiguracja.
                    </p>
                }
            </div>
            <div>
                @if (ksefConfigured)
                {
                    <form asp-action="Sync" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary-accent">
                            <i class="bi bi-arrow-repeat me-1"></i> Synchronizuj teraz
                        </button>
                    </form>
                }
                else
                {
                    <a href="/ksef/config" class="btn-primary-accent text-decoration-none">
                        <i class="bi bi-gear-fill me-1"></i> Przejdź do konfiguracji
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Lista Faktur z KSeF -->
    <div class="data-card p-0">
        <div class="data-card__header d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-sm-center p-3">
            <h3 class="data-card__title mb-0">
                <i class="bi bi-list-task me-2 text-primary"></i> Faktury kosztowe pobrane z KSeF
            </h3>
            <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-3">
                <div class="search-box" style="position: relative; width: 250px;">
                    <i class="bi bi-search" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
                    <input type="text" id="tableSearch" placeholder="Szukaj..." class="form-control form-control-sm" style="padding-left: 32px; background-color: var(--bg-tertiary); border-color: var(--border-strong);">
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="small text-secondary mb-0">Pokaż:</label>
                    <select id="pageSize" class="form-select form-select-sm" style="width: 70px; background-color: var(--bg-tertiary); border-color: var(--border-strong);">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                    </select>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="dx-datagrid-table" id="ksefTable">
                <thead class="dx-datagrid-headers">
                    <tr class="dx-header-row">
                        <th class="sortable" data-sort="date" style="width: 150px;">Data wystawienia <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable" data-sort="seller">Sprzedawca / NIP <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable" data-sort="ksef">Numer KSeF <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th class="sortable text-end" data-sort="amount" style="width: 150px;">Kwota brutto <i class="bi bi-arrow-down-up ms-1"></i></th>
                        <th style="width: 140px;" class="text-center">Status</th>
                        <th style="width: 320px;" class="text-center">Akcje</th>
                    </tr>
                </thead>
                <tbody class="dx-datagrid-rows" id="tableBody">
                    @if (!Model.Any())
                    {
                        <tr class="dx-row">
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-mailbox2 display-4 d-block mb-3"></i>
                                Brak pobranych faktur kosztowych. Kliknij "Synchronizuj teraz" lub skonfiguruj połączenie z KSeF.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var invoice in Model)
                        {
                            <tr class="dx-row ksef-row"
                                data-date="@invoice.IssueDate.ToString("yyyy-MM-dd")"
                                data-seller="@invoice.SellerName"
                                data-ksef="@invoice.KsefNumber"
                                data-amount="@invoice.TotalAmount.ToString("F2").Replace(",", ".")">
                                <td data-label="Data wystawienia" style="font-weight: 600; color: var(--text-primary);">
                                    @invoice.IssueDate.ToString("yyyy-MM-dd")
                                    <div class="text-secondary fw-normal small d-md-none" style="font-size: 0.7rem; margin-top: 2px;">
                                        KSeF: @(invoice.KsefNumber.Length > 20 ? invoice.KsefNumber[..20] + "..." : invoice.KsefNumber)
                                    </div>
                                </td>
                                <td data-label="Sprzedawca / NIP">
                                    <div style="font-weight: 600; color: var(--text-primary);">@invoice.SellerName</div>
                                    <div class="text-muted small">NIP: @invoice.SellerNip</div>
                                </td>
                                <td data-label="Numer KSeF">
                                    <span class="text-monospace small text-muted" title="@invoice.KsefNumber">
                                        @(invoice.KsefNumber.Length > 25 ? invoice.KsefNumber[..25] + "..." : invoice.KsefNumber)
                                    </span>
                                </td>
                                <td data-label="Kwota brutto" class="text-end" style="font-weight: 700; color: var(--text-primary);">
                                    @invoice.TotalAmount.ToString("N2") PLN
                                </td>
                                <td data-label="Status" class="text-center">
                                    @if (invoice.ImportStatus == KsefImportStatus.Pending)
                                    {
                                        <span class="badge-status badge-status--draft" style="border-color: rgba(245, 158, 11, 0.3); background-color: rgba(245, 158, 11, 0.1); color: #f59e0b;"><i class="bi bi-clock-history me-1"></i>Oczekuje</span>
                                    }
                                    else if (invoice.ImportStatus == KsefImportStatus.Imported)
                                    {
                                        <span class="badge-status badge-status--confirmed"><i class="bi bi-check-circle-fill me-1"></i>Zaimportowana</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-status--draft"><i class="bi bi-eye-slash-fill me-1"></i>Zignorowana</span>
                                    }
                                </td>
                                <td data-label="Akcje" class="text-center">
                                    <div class="d-flex justify-content-center gap-1 flex-wrap">
                                        <a href="/ksef/inbox/details/@invoice.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> Podgląd
                                        </a>
                                        
                                        @if (invoice.ImportStatus == KsefImportStatus.Pending)
                                        {
                                            <form asp-action="Import" asp-route-id="@invoice.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-plus-circle"></i> Importuj
                                                </button>
                                            </form>
                                            <form asp-action="Ignore" asp-route-id="@invoice.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" onclick="return confirm('Czy na pewno chcesz zignorować tę fakturę?')">
                                                    <i class="bi bi-slash-circle"></i> Ignoruj
                                                </button>
                                            </form>
                                        }
                                        else if (invoice.ImportStatus == KsefImportStatus.Imported)
                                        {
                                            <a href="/invoices" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-arrow-right-short"></i> Zobacz w systemie
                                            </a>
                                        }
                                        <a href="/ksef/inbox/xml/@invoice.Id" target="_blank" class="btn btn-sm btn-outline-secondary" title="Pobierz plik XML">
                                            <i class="bi bi-filetype-xml"></i> XML
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Paginacja Info & Numbers -->
        <div class="p-3 d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-center" style="background: var(--bg-tertiary); border-top: 1px solid var(--border);">
            <div id="paginationInfo" style="font-size: 0.8rem; color: var(--text-secondary); text-align: center;">Ładowanie...</div>
            <div class="d-flex align-items-center justify-content-center gap-2">
                <button id="prevPage" class="btn-secondary-outline btn-sm px-2"><i class="bi bi-chevron-left"></i></button>
                <div id="paginationNumbers" class="d-flex gap-1"></div>
                <button id="nextPage" class="btn-secondary-outline btn-sm px-2"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            let currentPage = 1;
            let pageSize = parseInt($('#pageSize').val());
            let sortColumn = 'date';
            let sortOrder = 'desc';

            function updateTable() {
                let $allRows = $('.ksef-row');
                let $rowsArray = $allRows.get();
                const searchTerm = $('#tableSearch').val().toLowerCase();

                // 1. Sortowanie
                $rowsArray.sort(function(a, b) {
                    let valA = $(a).data(sortColumn);
                    let valB = $(b).data(sortColumn);
                    if (sortColumn === 'amount' || sortColumn === 'date') {
                        let numA = parseFloat(valA);
                        let numB = parseFloat(valB);
                        if (sortColumn === 'date') {
                            numA = new Date(valA).getTime();
                            numB = new Date(valB).getTime();
                        }
                        return sortOrder === 'asc' ? (numA > numB ? 1 : -1) : (numB > numA ? 1 : -1);
                    }
                    return sortOrder === 'asc' ? valA.toString().localeCompare(valB.toString()) : valB.toString().localeCompare(valA.toString());
                });

                const $body = $('#tableBody');
                $.each($rowsArray, function(index, row) { $body.append(row); });

                // 2. Filtrowanie
                const $filteredRows = $('.ksef-row').filter(function() { 
                    return $(this).text().toLowerCase().indexOf(searchTerm) > -1; 
                });

                const totalItems = $filteredRows.length;
                const totalPages = Math.ceil(totalItems / pageSize);
                
                if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

                $allRows.hide();
                const start = (currentPage - 1) * pageSize;
                const textEnd = start + pageSize;
                $filteredRows.slice(start, textEnd).show();

                // 3. Renderowanie numerów stron
                const $numbersWrap = $('#paginationNumbers');
                $numbersWrap.empty();
                
                let startPage, endPage;
                if (totalPages <= 5) {
                    startPage = 1;
                    endPage = totalPages;
                } else {
                    if (currentPage <= 3) {
                        startPage = 1;
                        endPage = 5;
                    } else if (currentPage + 2 >= totalPages) {
                        startPage = totalPages - 4;
                        endPage = totalPages;
                    } else {
                        startPage = currentPage - 2;
                        endPage = currentPage + 2;
                    }
                }

                if (startPage > 1) {
                    const $btn = $('<button></button>').addClass('page-number').text(1)
                        .on('click', function() { currentPage = 1; updateTable(); });
                    $numbersWrap.append($btn);
                    if (startPage > 2) {
                        $numbersWrap.append($('<span></span>').addClass('px-2 align-self-center text-muted').text('...'));
                    }
                }

                for (let i = startPage; i <= endPage; i++) {
                    const $btn = $('<button></button>')
                        .addClass('page-number')
                        .text(i)
                        .toggleClass('active', i === currentPage)
                        .on('click', function() {
                            currentPage = i;
                            updateTable();
                        });
                    $numbersWrap.append($btn);
                }

                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        $numbersWrap.append($('<span></span>').addClass('px-2 align-self-center text-muted').text('...'));
                    }
                    const $btn = $('<button></button>').addClass('page-number').text(totalPages)
                        .on('click', function() { currentPage = totalPages; updateTable(); });
                    $numbersWrap.append($btn);
                }

                const showStart = totalItems === 0 ? 0 : start + 1;
                const showEnd = Math.min(textEnd, totalItems);
                $('#paginationInfo').html(`Pokazano <strong>${showStart}-${showEnd}</strong> z <strong>${totalItems}</strong> faktur`);
                
                $('#prevPage').prop('disabled', currentPage === 1);
                $('#nextPage').prop('disabled', currentPage >= totalPages || totalPages === 0);
            }

            $('.sortable').on('click', function() {
                const column = $(this).data('sort');
                if (sortColumn === column) sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
                else { sortColumn = column; sortOrder = 'asc'; }
                $('.sortable').removeClass('active').find('i').attr('class', 'bi bi-arrow-down-up');
                $(this).addClass('active').find('i').attr('class', sortOrder === 'asc' ? 'bi bi-sort-up' : 'bi bi-sort-down');
                updateTable();
            });

            $('#tableSearch').on('input', function() { currentPage = 1; updateTable(); });
            $('#pageSize').on('change', function() { pageSize = parseInt($(this).val()); currentPage = 1; updateTable(); });
            $('#prevPage').on('click', function() { if (currentPage > 1) { currentPage--; updateTable(); } });
            $('#nextPage').on('click', function() { 
                const searchTerm = $('#tableSearch').val().toLowerCase();
                const totalItems = $('.ksef-row').filter(function() { return $(this).text().toLowerCase().indexOf(searchTerm) > -1; }).length;
                if (currentPage < Math.ceil(totalItems / pageSize)) { currentPage++; updateTable(); } 
            });

            $('.sortable[data-sort="date"]').addClass('active').find('i').attr('class', 'bi bi-sort-down');
            updateTable();
        });
    </script>
    <style>
        .text-monospace {
            font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }
        .sortable { cursor: pointer; }
        .sortable i { opacity: 0.3; transition: opacity 0.2s; }
        .sortable.active i { opacity: 1; color: var(--accent); }
    </style>
}
