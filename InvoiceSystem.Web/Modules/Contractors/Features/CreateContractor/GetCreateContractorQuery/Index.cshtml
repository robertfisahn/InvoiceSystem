@model InvoiceSystem.Web.Modules.Contractors.Features.CreateContractor.GetCreateContractorQuery.CreateContractorViewModel
@{
    ViewData["Title"] = "Dodaj Nowego Kontrahenta";
    var warningMessage = Model.WarningMessage;
    var isOcrFlow = !string.IsNullOrWhiteSpace(Model.SessionId);
}

<div class="row justify-content-center" style="margin-top: var(--grid-gap);">
    <div class="col-xl-6 col-lg-8 col-md-10">
        <div class="data-card">
            <div class="data-card__header">
                <h3 class="data-card__title">
                    @if (isOcrFlow)
                    {
                        <i class="bi bi-person-plus-fill me-2 text-warning"></i> <span>Zarejestruj kontrahenta z AI OCR</span>
                    }
                    else
                    {
                        <i class="bi bi-person-add me-2 text-primary"></i> <span>Nowy Kontrahent</span>
                    }
                </h3>
            </div>
            <div class="data-card__body" style="padding: var(--card-padding);">
                @if (!string.IsNullOrEmpty(warningMessage))
                {
                    <div class="alert alert-warning mb-4" style="background: rgba(245, 158, 11, 0.1); border: none; border-left: 4px solid #f59e0b; color: #d97706;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @warningMessage
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4">
                        <div asp-validation-summary="All" class="small"></div>
                    </div>
                }

                <form asp-controller="CreateContractorCommand" asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SessionId" />

                    <div class="form-group mb-3 text-start">
                        <label class="form-label fw-bold small text-secondary" asp-for="Name">Nazwa firmy / kontrahenta</label>
                        <input asp-for="Name" class="form-control" placeholder="Wprowadź pełną nazwę firmy..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label class="form-label fw-bold small text-secondary" asp-for="TaxId">NIP (10 cyfr)</label>
                        <input asp-for="TaxId" class="form-control" placeholder="Np. 1234567890" required />
                        <span asp-validation-for="TaxId" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4 text-start">
                        <label class="form-label fw-bold small text-secondary" asp-for="Address">Adres pocztowy</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Wprowadź adres..."></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-primary-accent flex-grow-1 justify-content-center py-2">
                            <i class="bi bi-check-lg me-1"></i> 
                            <span>@(isOcrFlow ? "Zapisz i Przejdź do Faktury" : "Zapisz Kontrahenta")</span>
                        </button>
                        
                        @if (isOcrFlow)
                        {
                            <a href="/invoices/import" class="btn-secondary-outline justify-content-center py-2 px-3">
                                Anuluj
                            </a>
                        }
                        else
                        {
                            <a href="/contractors" class="btn-secondary-outline justify-content-center py-2 px-3">
                                Powrót do Listy
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
