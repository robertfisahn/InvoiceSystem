<!DOCTYPE html>
<html lang="pl" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvoiceSystem</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Core JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- App UI Specification CSS -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    
    <!-- Legacy/Specific Components -->
    <link rel="stylesheet" href="~/css/components/card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/badge.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/table.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/form.css" asp-append-version="true" />

    <!-- Theme script MUST run early -->
    <script src="~/js/theme.js" asp-append-version="true"></script>
</head>
<body class="dx-viewport">

    @await Html.PartialAsync("_TopBar")

    <div class="app-wrapper">
        @await Html.PartialAsync("_Sidebar")

        <main class="app-content" id="appContent">
            <div class="page-header no-print">
                <div class="page-header-left">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0" style="font-size: 0.85rem; background: transparent !important; padding: 0; border: none;">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none" style="color: var(--text-secondary);">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page" style="color: var(--accent);">@ViewData["Title"]</li>
                        </ol>
                    </nav>
                </div>
                <div class="page-header-actions">
                    @RenderSection("PageActions", required: false)
                </div>
            </div>
            
            <div class="content-body">
                @await Html.PartialAsync("Components/_Alert")
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- App UI Scripts -->
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
