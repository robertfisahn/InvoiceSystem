@if (TempData["SuccessMessage"] != null)
{
    <script>
        $(function() {
            DevExpress.ui.notify({
                message: @Html.Raw(Json.Serialize(TempData["SuccessMessage"])),
                type: "success",
                displayTime: 3000,
                position: { at: "top right", my: "top right", offset: "-20 20" },
                width: 300,
                shading: false
            });
        });
    </script>
}

@if (TempData["ErrorMessage"] != null)
{
    <script>
        $(function() {
            DevExpress.ui.notify({
                message: @Html.Raw(Json.Serialize(TempData["ErrorMessage"])),
                type: "error",
                displayTime: 5000,
                position: { at: "top right", my: "top right", offset: "-20 20" },
                width: 300,
                shading: false
            });
        });
    </script>
}
